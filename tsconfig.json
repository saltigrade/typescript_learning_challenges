{
  "compilerOptions": {
    "target": "es2020",
    "module": "es2020",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": ["@types/mocha", "@types/chai"],
    "strict": true
  },
  "include": ["typescript/**/*.ts", "tests/**/*.ts", "src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
